# ============================================================
# Obsidian 최적화 .gitignore
# ============================================================

# ------------------------------------------------------------
# [1] Obsidian 개인 설정 (공유 불필요)
# ------------------------------------------------------------
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json

# 단, 아래는 공유 권장 (주석 처리 = Git에 포함)
# .obsidian/app.json
# .obsidian/appearance.json
# .obsidian/core-plugins.json
# .obsidian/community-plugins.json
# .obsidian/graph.json
# .obsidian/plugins/

# ------------------------------------------------------------
# [2] Obsidian Sync (사용 시 제외)
# ------------------------------------------------------------
.obsidian/sync.json

# ------------------------------------------------------------
# [3] 첨부 파일 (용량 큰 바이너리)
# ------------------------------------------------------------
# 대용량 파일만 선택적 제외 (필요 시 주석 해제)
# 7. Attachments/*.pdf
# 7. Attachments/*.mp4
# 7. Attachments/*.mov
# 7. Attachments/*.zip
# 7. Attachments/*.psd
# 7. Attachments/*.ai

# ------------------------------------------------------------
# [4] OS 자동 생성 파일
# ------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------
# [5] 임시/백업 파일
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# ------------------------------------------------------------
# [6] 편집기 설정 (VSCode 등)
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# [7] Node.js (Obsidian 플러그인 개발 시)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# [8] 민감 정보 보호
# ------------------------------------------------------------
*.env
.env*
secrets.*
private/
